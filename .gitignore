Thumbs.db
Desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*~

# =============================================================================
# Testes, temporários e caches adicionais
# =============================================================================
*.local
tmp/
temp/
.node_repl_history
.parcel-cache/

